    int spanningTree(int V, vector<vector<int>> adj[]) {

        // Min Heap
        priority_queue<
            vector<int>,
            vector<vector<int>>,
            greater<vector<int>>
        > pq;

        // Visited array
        vector<int> vis(V, 0);

        // Stores MST edges
        vector<pair<int,int>> mst;

        // Total MST weight
        int sum = 0;

        // Push {weight, node, parent}
        // pq.push({?, ?, ?});
        pq.push({0,0,-1});

        while (!pq.empty()) {

            // Extract top element
  auto it=pq.top();pq.pop();
            // Get:
            // weight
            int wt=it[0];
            // node
            int node=it[1];
            // parent
            int parent=it[2];
            if(vis[node]==1){continue;}
            // If already visited
            // continue
                vis[node]=1;
            // Mark visited
            sum+=wt;
            // Add weight to answer
            if(parent!=-1){mst.push_back({parent,node});}
            // If parent != -1
            // store {parent, node} in mst

            // Traverse all neighbours
            for(const auto& nei:adj[node]){
                // Get adjacent node
                int adjnode=nei[0];
                 // Get edge weight
                 int wt=nei[1];
                  // If not visited
                if(vis[adjnode]==0){pq.push({wt,adjnode,node});}
            }
        }

        // Print MST edges
        for (auto edge : mst) {

            // print parent --- child
            cout<<edge.first<<" "<<edge.second<<"\n";
        }

        return sum;
    }
