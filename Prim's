#include <bits/stdc++.h>
using namespace std;

class Solution {
public:
    int spanningTree(int V, vector<vector<int>> adj[]) {

        // Min Heap
        priority_queue<
            pair<int,int>,
            vector<pair<int,int>>,
            greater<pair<int,int>>
        > pq;

        // Visited array
        vector<int> vis(V, 0);

        // Total MST weight
        int sum = 0;

        // Push the starting node
        // pq.push({?, ?});
        pq.push({0,0});

        while (!pq.empty()) {

            // Extract minimum weight edge
            auto it=pq.top();
            pq.pop();
            // Get weight and node
            int wt=it.first;int node=it.second;
            // If already visited, continue
            if(vis[node]==1) continue;
            // Mark node as visited
            vis[node]=1;
            // Add weight to answer
            sum+=wt;
            // Traverse all adjacent nodes
                 for(const auto& nei:adj[node]){
                // Get adjacent node
                int adjnode=nei[0];
                // Get edge weight
                      int wt=nei[1];
                // If not visited
                    if(vis[adjnode]==0){
                    // Push into priority queue
                    pq.push({wt,adjnode});
                    }
                 }
        }
        return sum;
    }
};

